<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>That Green Day Band | Chicago Green Day Tribute</title>
    
    <!-- Link to the new external stylesheet -->
    <link rel="stylesheet" href="style.css">

    <!-- [PASTE GTM HEAD SCRIPT HERE] -->
</head>
<body>
    <!-- [PASTE GTM BODY NOSCRIPT BLOCK HERE] -->

    <nav class="glass-panel">
        <div class="logo">
            <img src="logo.png" alt="TGDB">
        </div>
        <ul class="nav-links">
            <li><a href="#about">Bio</a></li>
            <li><a href="#shows">Tour</a></li>
            <li><a href="#media">Media</a></li>
        </ul>
    </nav>

    <header id="home">
        <div class="hero-content">
            <h1 class="hero-title">
                THAT <span class="text-neon">GREEN DAY</span> BAND
            </h1>
            <p class="hero-subtitle">The world's #1 Green Day tribute band<br />since 2008!</p>
        </div>
    </header>

    <main>
        <section id="about">
            <div class="bio-grid">
                <div class="bio-image">
                    <img src="group-shot_2.png" alt="That Green Day Band" style="width: 100%; display: block;">
                </div>
                <div class="bio-text glass-panel">
                    <h2 class="section-title" style="text-align: left; margin-bottom: 2rem;">LOUD & <span class="text-neon">FAST</span></h2>
                    <p>That Green Day Band doesn't just play the songs. We bring the chaotic, high-voltage energy of early 90s punk back to the stage.</p>
                    <p>Focusing on the entire Green Day catalog from *Kerplunk!* to *Saviors* and everything in-between, TGDB strips away the bloat and delivers the raw anthems that defined a generation.</p>
                </div>
            </div>
        </section>

        <section id="shows">
            <h2 class="section-title text-outline">LIVE CONCERTS</h2>
            <div class="shows-container glass-panel">
                <p style="font-family: 'Anton'; font-size: 1.5rem; letter-spacing: 2px;">[ PASTE BANDSINTOWN IFRAME HERE ]</p>
            </div>
        </section>

        <section id="media">
            <h2 class="section-title">THE <span class="text-neon">ARCHIVE</span></h2>
            <div class="media-grid">
                <div class="video-box">
                    [ YOUTUBE EMBED ]
                </div>
                <div class="video-box">
                    [ YOUTUBE EMBED ]
                </div>
                <div class="audio-box glass-panel">
                    <p style="font-family: 'Anton'; font-size: 1.5rem; letter-spacing: 2px; color: #666;">[ SPOTIFY PLAYER EMBED ]</p>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="socials">
            <a href="#">INSTAGRAM</a>
            <a href="#">YOUTUBE</a>
            <a href="#">BOOKING</a>
        </div>
        <p style="color: #666; font-size: 0.9rem;">&copy; 2026 That Green Day Band.</p>
    </footer>
