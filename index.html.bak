    <!-- MODAL HTML STRUCTURE -->
    <div id="showModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">&times;</span>
            <h3 class="modal-title" id="modalVenue">Venue Name</h3>
            <div class="modal-details">
                <p id="modalDate">Date</p>
                <p id="modalTime">Time</p>
                <p id="modalAddress">(address not available)<br />
                <p id="modalCityStateZip">(city not available)<br />
                <p id="modalPhone">(phone number not available)</p>
                <p id="modalNotes" style="color: var(--hot-pink); margin-top: 1.5rem; font-weight: bold;"></p>
            </div>
        </div>
    </div>

    <!-- JAVASCRIPT FOR MODAL INTERACTION -->
    <script>
        const modal = document.getElementById("showModal");

        function openModal(venue, date, time, address, cityStateZip, phone, notes) {
            document.getElementById("modalVenue").innerText = venue;
            document.getElementById("modalDate").innerText = date;
            document.getElementById("modalTime").innerText = time;
            document.getElementById("modalAddress").innerText = address;
            document.getElementById("modalCityStateZip").innerText = cityStateZip;
            document.getElementById("modalPhone").innerText = phone;
            document.getElementById("modalNotes").innerText = notes;
            modal.style.display = "flex";
        }

        function closeModal() {
            modal.style.display = "none";
        }

        // Close modal if user clicks anywhere outside the box
        window.onclick = function(event) {
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>

<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v4513226cdae34746b4dedf0b4dfa099e1781791509496" integrity="sha512-ZE9pZaUXND66v380QUtch/5sE9tPFh2zg45pR2PB0CVkCtOREv2AJKkSidISWkysEuQ0EH8faUU5du78bx87UQ==" data-cf-beacon='{"version":"2024.11.0","token":"4bb4da0e775347f1a2bf1a5d3f236640","r":1,"server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>

<!-- LIGHTBOX STRUCTURE -->
    <div id="galleryLightbox" class="lightbox" onclick="closeLightbox()">
        <span class="lightbox-close">&times;</span>
        <img class="lightbox-content" id="lightboxImg" src="" alt="Enlarged view">
    </div>

    <!-- LIGHTBOX INTERACTION SCRIPT -->
    <script>
        const lightbox = document.getElementById("galleryLightbox");
        const lightboxImg = document.getElementById("lightboxImg");

        function openLightbox(imageSrc) {
            lightboxImg.src = imageSrc;
            lightbox.style.display = "flex";
        }

        function closeLightbox() {
            lightbox.style.display = "none";
            lightboxImg.src = ""; // Clear src to stop image loading artifacts
        }
    </script>

</body>
</html>