    <footer>
	<section id="contact">
        <div class="socials">
            <a href="https://www.instagram.com/thatgreendayband/" target="_blank">INSTAGRAM</a>
            <a href="https://www.facebook.com/thatgreendayband" target="_blank">FACEBOOK</a>
